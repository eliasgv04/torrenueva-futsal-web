---
interface Props {
  dorsal: number | null;
  nombre: string;
  posicion: string;
  foto: string;
  fotoZoom?: number;
  fotoPosicion?: string;
}

const { dorsal, nombre, posicion, foto, fotoZoom = 1, fotoPosicion = 'center center' } = Astro.props;
---

<article class="tarjeta jugador-tarjeta">
  <div class="jugador-foto-wrap">
    <img
      src={foto}
      alt={`Foto de ${nombre}`}
      class="jugador-foto"
      style={`--foto-zoom: ${fotoZoom}; --foto-posicion: ${fotoPosicion};`}
      loading="lazy"
      width="300"
      height="400"
    />
    {dorsal != null && (
      <span class="jugador-dorsal" aria-label={`Dorsal ${dorsal}`}>{dorsal}</span>
    )}
  </div>
  <div class="tarjeta-cuerpo">
    <p class="jugador-nombre">{nombre}</p>
    <p class="jugador-posicion">{posicion}</p>
  </div>
</article>

<style>
.jugador-tarjeta { text-align: center; }

.jugador-foto-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/4;
}
.jugador-foto {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: var(--foto-posicion, center center);
  transform: scale(var(--foto-zoom, 1));
  transition: transform .4s ease;
  filter: grayscale(20%);
}
.jugador-tarjeta:hover .jugador-foto {
  transform: scale(calc(var(--foto-zoom, 1) * 1.06));
  filter: grayscale(0%);
}

.jugador-dorsal {
  position: absolute;
  top: .6rem;
  left: .6rem;
  background: var(--color-acento);
  color: #000;
  font-family: var(--fuente-titulo);
  font-size: 1.1rem;
  letter-spacing: .04em;
  padding: .15rem .55rem .1rem;
  border-radius: var(--radio-borde);
  line-height: 1.4;
}

.tarjeta-cuerpo { padding: 1rem 1.1rem 1.2rem; }

.jugador-nombre {
  font-family: var(--fuente-titulo);
  font-size: .95rem;
  letter-spacing: .04em;
  color: var(--color-texto);
  margin-bottom: .3rem;
  line-height: 1.2;
}

.jugador-posicion {
  font-size: .75rem;
  color: var(--color-acento);
  text-transform: uppercase;
  letter-spacing: .1em;
  font-weight: 700;
}
</style>
