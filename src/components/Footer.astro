---
const anio = new Date().getFullYear();
---

<footer class="pie">
  <div class="pie-interior">

    <!-- Marca -->
    <div class="pie-marca">
      <div class="pie-logo-texto">
        <span class="pie-playfair">torrenueva</span>
        <span class="pie-anton">FUTSAL</span>
      </div>
      <p class="pie-subtitulo">Club de Fútbol Sala · Torrenueva, Ciudad Real</p>

      <ul class="pie-social" role="list">
        <li>
          <a href="https://www.instagram.com/torrenuevafutsal/" target="_blank" rel="noopener noreferrer" aria-label="Instagram del Torrenueva Futsal">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37Z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
        </li>
        <li>
          <a href="https://chat.whatsapp.com/L6XjVTLiwxNA6sY3yjsbUe" target="_blank" rel="noopener noreferrer" aria-label="Grupo de WhatsApp del Torrenueva Futsal">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>
            </svg>
          </a>
        </li>
        <li>
          <a href="mailto:torrenuevafutsal2021@gmail.com" aria-label="Enviar correo al Torrenueva Futsal">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect x="2" y="4" width="20" height="16" rx="2"/>
              <path d="m22 7-10 5L2 7"/>
            </svg>
          </a>
        </li>
      </ul>
    </div>

    <!-- Navegación -->
    <nav aria-label="Pie de página">
      <p class="pie-nav-titulo">Secciones</p>
      <ul class="pie-enlaces" role="list">
        <li><a href="/noticias">Noticias</a></li>
        <li><a href="/plantilla">Plantilla</a></li>
        <li><a href="/calendario">Calendario</a></li>
        <li><a href="/historia">Nuestra historia</a></li>
        <li><a href="/tienda">Tienda</a></li>
        <li><a href="/aviso-legal">Aviso legal</a></li>
      </ul>
    </nav>

  </div>

  <div class="pie-patrocinadores">
    <p class="pie-patrocinadores-titulo">Patrocinadores</p>
    <div class="pie-patrocinadores-imgwrap">
      <img src="/images/Patrocinadores.png" alt="Patrocinadores del Torrenueva Futsal" class="pie-patrocinadores-img" />
    </div>
    <p class="pie-patrocinadores-cta">
      ¿Quieres patrocinarnos? Escríbenos a
      <a href="mailto:torrenuevafutsal2021@gmail.com">torrenuevafutsal2021@gmail.com</a>
    </p>
  </div>

  <div class="pie-copyright">
    <p>© {anio} Torrenueva Futsal. Todos los derechos reservados.</p>
  </div>
</footer>

<style>
.pie {
  background: #050505;
  border-top: 1px solid #1e1e1e;
  margin-top: auto;
}

.pie-interior {
  max-width: var(--max-ancho);
  margin: 0 auto;
  padding: 3rem 1.5rem 2rem;
  display: grid;
  grid-template-columns: 1fr auto;
  gap: 2rem 4rem;
  align-items: start;
}

/* Logo pie */
.pie-logo-texto {
  display: flex;
  flex-direction: column;
  line-height: 1;
  margin-bottom: .75rem;
}
.pie-playfair {
  font-family: var(--fuente-display);
  font-style: italic;
  font-weight: 600;
  font-size: 1.3rem;
  color: var(--color-acento);
  display: block;
  letter-spacing: .01em;
}
.pie-anton {
  font-family: var(--fuente-titulo);
  font-size: .68rem;
  color: #fff;
  display: block;
  letter-spacing: .08em;
  margin-top: -3px; /* FUTSAL se monta ligeramente sobre torrenueva */
}

.pie-subtitulo {
  font-size: .8rem;
  color: var(--color-texto-tenue);
  margin-top: .5rem;
}

/* Redes sociales */
.pie-social {
  display: flex;
  gap: .75rem;
  margin-top: 1.25rem;
}
.pie-social a {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: 1px solid var(--color-borde);
  color: var(--color-texto-sec);
  transition: color .15s, border-color .15s;
}
.pie-social a:hover {
  color: var(--color-acento);
  border-color: var(--color-acento);
}

/* Nav pie */
.pie-nav-titulo {
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--color-texto-tenue);
  margin-bottom: .75rem;
}

.pie-enlaces {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  gap: .5rem 1.5rem;
}
.pie-enlaces a {
  font-size: .85rem;
  color: var(--color-texto-sec);
  transition: color .15s;
}
.pie-enlaces a:hover { color: var(--color-acento); text-decoration: none; }

/* Patrocinadores */
.pie-patrocinadores {
  border-top: 1px solid #1a1a1a;
  padding: 2rem 1.5rem;
  text-align: center;
}
.pie-patrocinadores-titulo {
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--color-texto-tenue);
  margin-bottom: 1.25rem;
}
.pie-patrocinadores-imgwrap {
  width: 100%;
  max-width: 1100px;
  aspect-ratio: 11 / 1;
  overflow: hidden;
  margin: 0 auto;
}
.pie-patrocinadores-img {
  display: block;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: bottom;
}
.pie-patrocinadores-cta {
  font-size: .82rem;
  color: var(--color-texto-sec);
  margin-top: 1.5rem;
}
.pie-patrocinadores-cta a { color: var(--color-acento); }
.pie-patrocinadores-cta a:hover { text-decoration: underline; }

/* Copyright */
.pie-copyright {
  border-top: 1px solid #1a1a1a;
  padding: 1rem 1.5rem;
  text-align: center;
}
.pie-copyright p {
  font-size: .75rem;
  color: var(--color-texto-tenue);
}

@media (max-width: 600px) {
  .pie-interior { grid-template-columns: 1fr; }
}
</style>
