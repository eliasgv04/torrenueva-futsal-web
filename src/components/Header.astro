---
const navLinks = [
  { href: '/',           texto: 'Inicio' },
  { href: '/noticias',   texto: 'Noticias' },
  { href: '/plantilla',  texto: 'Plantilla' },
  { href: '/calendario', texto: 'Calendario' },
  { href: '/historia',   texto: 'Nuestra historia' },
  { href: '/tienda',     texto: 'Tienda' },
];

const ruta = Astro.url.pathname;
---

<header class="cabecera">
  <div class="cabecera-interior">

    <!-- Logo tipográfico: Playfair italic amarillo + Anton blanco encima -->
    <a href="/" class="logo" aria-label="Torrenueva Futsal — Inicio">
      <img src="/images/Escudo.PNG" alt="Escudo Torrenueva Futsal" width="42" height="42" class="escudo-img" />
      <div class="logo-texto">
        <span class="logo-playfair">torrenueva</span>
        <span class="logo-anton">FUTSAL</span>
      </div>
    </a>

    <!-- Hamburguesa móvil -->
    <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="navMenu">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>

    <!-- Navegación -->
    <nav id="navMenu" class="nav" aria-label="Navegación principal">
      <ul class="nav-lista" role="list">
        {navLinks.map(({ href, texto }) => {
          const activo = ruta === href || (href !== '/' && ruta.startsWith(href));
          return (
            <li>
              <a
                href={href}
                class={`nav-enlace${activo ? ' activo' : ''}`}
                aria-current={activo ? 'page' : undefined}
              >
                {texto}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('navToggle');
  const menu   = document.getElementById('navMenu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('abierto');
    toggle.setAttribute('aria-expanded', String(open));
    toggle.classList.toggle('activo');
  });
</script>

<style>
.cabecera {
  background: #0a0a0a;
  border-bottom: 1px solid #1e1e1e;
  position: sticky;
  top: 0;
  z-index: 100;
}

.cabecera-interior {
  max-width: var(--max-ancho);
  margin: 0 auto;
  padding: .9rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

/* ── Logo ── */
.logo {
  display: flex;
  align-items: center;
  gap: .75rem;
  text-decoration: none;
  flex-shrink: 0;
}
.logo:hover { text-decoration: none; opacity: .85; }

.escudo-img {
  width: 42px;
  height: 42px;
  object-fit: cover;
  flex-shrink: 0;
}

/* Tratamiento tipográfico: Playfair italic amarillo grande + Anton blanco pequeño debajo */
.logo-texto {
  display: flex;
  flex-direction: column;
  line-height: 1;
  gap: 0;
}
.logo-playfair {
  font-family: var(--fuente-display);
  font-style: italic;
  font-weight: 600;
  font-size: 1.3rem;
  color: var(--color-acento);
  display: block;
  position: relative;
  z-index: 1;
  letter-spacing: .01em;
}
.logo-anton {
  font-family: var(--fuente-titulo);
  font-size: .65rem;
  color: #fff;
  display: block;
  position: relative;
  z-index: 2;
  letter-spacing: .08em;
  line-height: 1;
  margin-top: -3px; /* FUTSAL se monta ligeramente sobre torrenueva */
}

/* ── Hamburguesa ── */
.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: .4rem;
  margin-left: auto;
}
.bar {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--color-texto);
  border-radius: 2px;
  transition: transform .2s, opacity .2s;
}
.nav-toggle.activo .bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
.nav-toggle.activo .bar:nth-child(2) { opacity: 0; }
.nav-toggle.activo .bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

/* ── Nav ── */
.nav { margin-left: auto; }
.nav-lista { display: flex; gap: .1rem; align-items: center; }

.nav-enlace {
  color: var(--color-texto-sec);
  padding: .45rem .9rem;
  border-radius: var(--radio-borde);
  font-size: .82rem;
  font-weight: 600;
  letter-spacing: .07em;
  text-transform: uppercase;
  transition: color .15s, background .15s;
  text-decoration: none;
}
.nav-enlace:hover { color: var(--color-texto); background: rgba(255,255,255,.05); text-decoration: none; }
.nav-enlace.activo { color: var(--color-acento); }

/* ── Responsive ── */
@media (max-width: 700px) {
  .nav-toggle { display: flex; }
  .nav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0; right: 0;
    background: #0a0a0a;
    border-top: 1px solid #1e1e1e;
    border-bottom: 1px solid #1e1e1e;
    padding: 1rem 1.5rem 1.5rem;
  }
  .nav.abierto { display: block; }
  .nav-lista { flex-direction: column; align-items: stretch; gap: .25rem; }
  .nav-enlace { display: block; padding: .7rem 1rem; }
}
</style>
