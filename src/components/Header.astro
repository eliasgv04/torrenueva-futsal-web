---
const navLinks = [
  { href: '/',           texto: 'Inicio' },
  { href: '/noticias',   texto: 'Noticias' },
  { href: '/jugadores',  texto: 'Jugadores' },
  { href: '/calendario', texto: 'Calendario' },
  { href: '/tienda',     texto: 'Tienda' },
];

const rutaActual = Astro.url.pathname;
---

<header class="cabecera">
  <div class="cabecera-interior">
    <!-- Logo y nombre del club -->
    <a href="/" class="logo" aria-label="Torrenueva Futsal — Inicio">
      <div class="escudo" aria-hidden="true">
        <!-- Sustituye esta imagen cuando tengas el escudo real:
             <img src="/images/escudo.png" alt="Escudo Torrenueva Futsal" width="48" height="48" /> -->
        <span class="escudo-placeholder">⚽</span>
      </div>
      <span class="club-nombre">Torrenueva<br /><strong>Futsal</strong></span>
    </a>

    <!-- Botón hamburguesa (solo móvil) -->
    <button class="nav-toggle" id="navToggle" aria-label="Abrir menú" aria-expanded="false" aria-controls="navMenu">
      <span class="hamburguesa-linea"></span>
      <span class="hamburguesa-linea"></span>
      <span class="hamburguesa-linea"></span>
    </button>

    <!-- Menú de navegación -->
    <nav id="navMenu" class="nav" aria-label="Navegación principal">
      <ul class="nav-lista" role="list">
        {navLinks.map(({ href, texto }) => {
          const activo = rutaActual === href || (href !== '/' && rutaActual.startsWith(href));
          return (
            <li>
              <a href={href} class={`nav-enlace${activo ? ' activo' : ''}`} aria-current={activo ? 'page' : undefined}>
                {texto}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.getElementById('navToggle');
  const menu = document.getElementById('navMenu');
  toggle?.addEventListener('click', () => {
    const abierto = menu?.classList.toggle('abierto');
    toggle.setAttribute('aria-expanded', String(abierto));
  });
</script>

<style>
.cabecera {
  background: var(--color-primario);
  color: var(--color-blanco);
  position: sticky;
  top: 0;
  z-index: 100;
  box-shadow: 0 2px 8px rgba(0,0,0,.25);
}

.cabecera-interior {
  max-width: var(--max-ancho);
  margin: 0 auto;
  padding: .75rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 1.5rem;
}

/* Logo */
.logo {
  display: flex;
  align-items: center;
  gap: .75rem;
  color: var(--color-blanco);
  text-decoration: none;
  flex-shrink: 0;
}
.logo:hover { text-decoration: none; opacity: .9; }

.escudo {
  width: 48px;
  height: 48px;
  background: var(--color-acento);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  overflow: hidden;
}
.escudo img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
.escudo-placeholder { font-size: 1.5rem; line-height: 1; }

.club-nombre {
  font-size: .95rem;
  line-height: 1.2;
  letter-spacing: .02em;
}
.club-nombre strong { font-size: 1.15rem; display: block; color: var(--color-acento); }

/* Hamburguesa */
.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: .4rem;
  margin-left: auto;
}
.hamburguesa-linea {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--color-blanco);
  border-radius: 2px;
  transition: transform .2s, opacity .2s;
}

/* Nav */
.nav { margin-left: auto; }
.nav-lista {
  display: flex;
  gap: .25rem;
  align-items: center;
}

.nav-enlace {
  color: var(--color-blanco);
  padding: .45rem .85rem;
  border-radius: var(--radio-borde);
  font-size: .9rem;
  font-weight: 500;
  transition: background .15s, color .15s;
  text-decoration: none;
}
.nav-enlace:hover { background: rgba(255,255,255,.15); text-decoration: none; }
.nav-enlace.activo {
  background: var(--color-acento);
  color: var(--color-negro);
  font-weight: 700;
}

/* Responsive */
@media (max-width: 700px) {
  .nav-toggle { display: flex; }

  .nav {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: var(--color-primario);
    padding: 1rem 1.5rem;
    box-shadow: 0 4px 12px rgba(0,0,0,.3);
  }
  .nav.abierto { display: block; }

  .nav-lista { flex-direction: column; align-items: stretch; gap: .25rem; }
  .nav-enlace { display: block; padding: .75rem 1rem; }
}
</style>
