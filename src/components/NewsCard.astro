---
interface Props {
  titulo: string;
  fecha: Date;
  imagen: string;
  descripcion: string;
  slug: string;
}

const { titulo, fecha, imagen, descripcion, slug } = Astro.props;

const fechaFormateada = fecha.toLocaleDateString('es-ES', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="tarjeta noticia-tarjeta">
  <a href={`/noticias/${slug}`} class="imagen-enlace" tabindex="-1" aria-hidden="true">
    <img
      src={imagen}
      alt={titulo}
      class="tarjeta-imagen"
      loading="lazy"
      width="800"
      height="800"
    />
  </a>
  <div class="tarjeta-cuerpo">
    <time class="noticia-fecha" datetime={fecha.toISOString()}>{fechaFormateada}</time>
    <h3 class="noticia-titulo">
      <a href={`/noticias/${slug}`}>{titulo}</a>
    </h3>
    <p class="noticia-desc">{descripcion}</p>
    <a href={`/noticias/${slug}`} class="noticia-leer" aria-label={`Leer: ${titulo}`}>
      Leer noticia
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</article>

<style>
.noticia-tarjeta { display: flex; flex-direction: column; }

.imagen-enlace { display: block; overflow: hidden; }
.imagen-enlace img { transition: transform .4s ease; }
.tarjeta:hover .imagen-enlace img { transform: scale(1.05); }

.noticia-fecha {
  font-size: .75rem;
  color: var(--color-acento);
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  display: block;
  margin-bottom: .6rem;
}

.noticia-titulo {
  font-family: var(--fuente-titulo);
  font-size: 1.15rem;
  font-weight: 400;
  letter-spacing: .03em;
  line-height: 1.25;
  margin-bottom: .7rem;
}
.noticia-titulo a { color: var(--color-texto); text-decoration: none; }
.noticia-titulo a:hover { color: var(--color-acento); }

.noticia-desc {
  font-size: .88rem;
  color: var(--color-texto-sec);
  line-height: 1.6;
  margin-bottom: 1.25rem;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex-grow: 1;
}

.noticia-leer {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  font-size: .78rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--color-acento);
  text-decoration: none;
  transition: gap .15s;
}
.noticia-leer:hover { gap: .65rem; text-decoration: none; }
</style>
