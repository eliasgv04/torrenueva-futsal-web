---
interface Props {
  nombre: string;
  cargo: string;
  foto: string;
}

const { nombre, cargo, foto } = Astro.props;
---

<article class="tarjeta staff-tarjeta">
  <div class="staff-foto-wrap">
    <img
      src={foto}
      alt={`Foto de ${nombre}`}
      class="staff-foto"
      loading="lazy"
      width="300"
      height="400"
    />
  </div>
  <div class="tarjeta-cuerpo">
    <p class="staff-nombre">{nombre}</p>
    <p class="staff-cargo">{cargo}</p>
  </div>
</article>

<style>
.staff-tarjeta { text-align: center; }

.staff-foto-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 3/4;
}
.staff-foto {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .4s ease;
  filter: grayscale(20%);
}
.staff-tarjeta:hover .staff-foto {
  transform: scale(1.06);
  filter: grayscale(0%);
}

.tarjeta-cuerpo { padding: 1rem 1.1rem 1.2rem; }

.staff-nombre {
  font-family: var(--fuente-titulo);
  font-size: .95rem;
  letter-spacing: .04em;
  color: var(--color-texto);
  margin-bottom: .3rem;
  line-height: 1.2;
}

.staff-cargo {
  font-size: .75rem;
  color: var(--color-acento);
  text-transform: uppercase;
  letter-spacing: .1em;
  font-weight: 700;
}
</style>
