---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias.map(noticia => ({
    params: { slug: noticia.id.replace(/\.md$/, '') },
    props: { noticia },
  }));
}

const { noticia } = Astro.props;
const { Content } = await render(noticia);

const fechaFormateada = noticia.data.fecha.toLocaleDateString('es-ES', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<Layout
  titulo={noticia.data.titulo}
  descripcion={noticia.data.descripcion}
  imagen={noticia.data.imagen}
  tipo="article"
>
  <article class="articulo">
    <header class="articulo-cabecera">
      <img
        src={noticia.data.imagen}
        alt={noticia.data.titulo}
        class="articulo-imagen-principal"
        width="1200"
        height="675"
      />
      <div class="articulo-meta">
        <a href="/noticias" class="breadcrumb">← Volver a noticias</a>
        <time class="articulo-fecha" datetime={noticia.data.fecha.toISOString()}>
          {fechaFormateada}
        </time>
        {noticia.data.autor && <p class="articulo-autor">Por {noticia.data.autor}</p>}
      </div>
      <h1 class="articulo-titulo">{noticia.data.titulo}</h1>
      <p class="articulo-descripcion">{noticia.data.descripcion}</p>
    </header>

    <div class="articulo-cuerpo prose">
      <Content />
    </div>
  </article>
</Layout>

<style>
.articulo {
  max-width: 800px;
  margin: 0 auto;
  padding: 2rem 1.5rem 4rem;
}

.articulo-imagen-principal {
  width: 100%;
  border-radius: var(--radio-borde-lg);
  aspect-ratio: 16/9;
  object-fit: cover;
  margin-bottom: 1.5rem;
}

.articulo-meta {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  flex-wrap: wrap;
  margin-bottom: .75rem;
}

.breadcrumb {
  font-size: .85rem;
  color: var(--color-primario);
  font-weight: 600;
}
.breadcrumb:hover { text-decoration: underline; }

.articulo-fecha {
  font-size: .85rem;
  color: var(--color-gris-texto);
}

.articulo-autor {
  font-size: .85rem;
  color: var(--color-gris-texto);
}

.articulo-titulo {
  font-size: clamp(1.6rem, 4vw, 2.4rem);
  font-weight: 800;
  line-height: 1.2;
  color: var(--color-primario);
  margin-bottom: .75rem;
}

.articulo-descripcion {
  font-size: var(--tamano-lg);
  color: var(--color-gris-texto);
  border-left: 4px solid var(--color-acento);
  padding-left: 1rem;
  margin-bottom: 2rem;
  font-style: italic;
}

/* Estilos del contenido Markdown */
.prose { line-height: 1.75; font-size: 1.05rem; }
.prose :global(h2) {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--color-primario);
  margin: 2rem 0 .75rem;
  padding-bottom: .4rem;
  border-bottom: 2px solid var(--color-acento);
}
.prose :global(h3) {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--color-primario);
  margin: 1.5rem 0 .5rem;
}
.prose :global(p) { margin-bottom: 1.2rem; }
.prose :global(ul), .prose :global(ol) {
  margin: 0 0 1.2rem 1.5rem;
  list-style: disc;
}
.prose :global(ol) { list-style: decimal; }
.prose :global(li) { margin-bottom: .4rem; }
.prose :global(blockquote) {
  border-left: 4px solid var(--color-acento);
  padding: .75rem 1.25rem;
  margin: 1.5rem 0;
  background: var(--color-gris-claro);
  border-radius: 0 var(--radio-borde) var(--radio-borde) 0;
  color: var(--color-gris-texto);
  font-style: italic;
}
.prose :global(strong) { font-weight: 700; color: var(--color-negro); }
.prose :global(a) { color: var(--color-primario); text-decoration: underline; }
</style>
