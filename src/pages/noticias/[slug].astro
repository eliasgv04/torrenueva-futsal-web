---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const noticias = await getCollection('noticias');
  return noticias.map(n => ({
    params: { slug: n.id.replace(/\.md$/, '') },
    props:  { noticia: n },
  }));
}

const { noticia } = Astro.props;
const { Content }  = await render(noticia);

const fechaFormateada = noticia.data.fecha.toLocaleDateString('es-ES', {
  weekday: 'long',
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});

const urlCompleta = new URL(Astro.url.pathname, Astro.site).toString();
const urlWhatsapp = `https://wa.me/?text=${encodeURIComponent(`${noticia.data.titulo} ${urlCompleta}`)}`;
---

<Layout
  titulo={noticia.data.titulo}
  descripcion={noticia.data.descripcion}
  imagen={noticia.data.imagen}
  tipo="article"
>
  <article class="articulo">

    <!-- Imagen principal -->
    <div class="articulo-hero">
      <img
        src={noticia.data.imagen}
        alt={noticia.data.titulo}
        class="articulo-hero-img"
        width="1200"
        height="675"
      />
      <div class="articulo-hero-overlay" aria-hidden="true"></div>
    </div>

    <!-- Contenido -->
    <div class="articulo-wrap">
      <div class="articulo-meta">
        <a href="/noticias" class="volver">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Volver a noticias
        </a>
        <time datetime={noticia.data.fecha.toISOString()} class="meta-fecha">
          {fechaFormateada}
        </time>
        {noticia.data.autor && <span class="meta-autor">Por {noticia.data.autor}</span>}
      </div>

      <h1 class="articulo-titulo">{noticia.data.titulo}</h1>
      <p class="articulo-entradilla">{noticia.data.descripcion}</p>

      <div class="compartir">
        <span class="compartir-label">Compartir</span>
        <a href={urlWhatsapp} target="_blank" rel="noopener noreferrer" class="compartir-btn" aria-label="Compartir en WhatsApp">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>
          </svg>
          WhatsApp
        </a>
        <button type="button" class="compartir-btn" data-copiar-enlace={urlCompleta} aria-label="Copiar enlace de la noticia">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
          </svg>
          <span data-copiar-texto>Copiar enlace</span>
        </button>
      </div>

      <div class="prose">
        <Content />
      </div>
    </div>

  </article>
</Layout>

<script>
  document.querySelectorAll<HTMLButtonElement>('[data-copiar-enlace]').forEach(boton => {
    boton.addEventListener('click', async () => {
      const url = boton.dataset.copiarEnlace ?? '';
      const texto = boton.querySelector('[data-copiar-texto]');
      try {
        await navigator.clipboard.writeText(url);
        if (texto) {
          const original = texto.textContent;
          texto.textContent = '¡Enlace copiado!';
          setTimeout(() => { texto.textContent = original; }, 2000);
        }
      } catch {
        // Portapapeles no disponible; no se hace nada
      }
    });
  });
</script>

<style>
.articulo { max-width: 100%; }

/* Hero imagen */
.articulo-hero {
  position: relative;
  height: clamp(220px, 40vw, 480px);
  overflow: hidden;
}
.articulo-hero-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  filter: brightness(.7);
}
.articulo-hero-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, var(--color-fondo) 0%, transparent 60%);
}

/* Wrap texto */
.articulo-wrap {
  max-width: 780px;
  margin: 0 auto;
  padding: 2.5rem 1.5rem 5rem;
}

.articulo-meta {
  display: flex;
  align-items: center;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-bottom: 1.5rem;
}

.volver {
  display: inline-flex;
  align-items: center;
  gap: .4rem;
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .1em;
  text-transform: uppercase;
  color: var(--color-texto-sec);
  text-decoration: none;
  transition: color .15s;
}
.volver:hover { color: var(--color-acento); text-decoration: none; }

.meta-fecha {
  font-size: .75rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  color: var(--color-acento);
}

.meta-autor {
  font-size: .75rem;
  color: var(--color-texto-sec);
}

.articulo-titulo {
  font-family: var(--fuente-titulo);
  font-size: clamp(1.8rem, 4vw, 3rem);
  font-weight: 400;
  letter-spacing: .03em;
  color: var(--color-texto);
  line-height: 1.15;
  margin-bottom: 1.25rem;
}

.articulo-entradilla {
  font-size: 1.1rem;
  color: var(--color-texto-sec);
  border-left: 3px solid var(--color-acento);
  padding-left: 1.25rem;
  margin-bottom: 2.5rem;
  line-height: 1.65;
  font-style: italic;
}

/* Compartir */
.compartir {
  display: flex;
  align-items: center;
  gap: .75rem;
  flex-wrap: wrap;
  padding-bottom: 2rem;
  margin-bottom: 2.5rem;
  border-bottom: 1px solid var(--color-borde);
}
.compartir-label {
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  color: var(--color-texto-tenue);
}
.compartir-btn {
  display: inline-flex;
  align-items: center;
  gap: .5rem;
  font-family: inherit;
  font-size: .82rem;
  font-weight: 600;
  color: var(--color-texto-sec);
  background: transparent;
  border: 1px solid var(--color-borde);
  border-radius: var(--radio-borde);
  padding: .5rem .9rem;
  cursor: pointer;
  text-decoration: none;
  transition: color .15s, border-color .15s;
}
.compartir-btn:hover {
  color: var(--color-acento);
  border-color: var(--color-acento);
  text-decoration: none;
}

/* Contenido Markdown */
.prose { line-height: 1.8; font-size: 1rem; color: var(--color-texto-sec); }
.prose :global(h2) {
  font-family: var(--fuente-titulo);
  font-size: 1.4rem;
  font-weight: 400;
  letter-spacing: .04em;
  color: var(--color-texto);
  margin: 2.5rem 0 .75rem;
  padding-bottom: .5rem;
  border-bottom: 1px solid var(--color-borde);
  position: relative;
}
.prose :global(h2)::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  width: 32px;
  height: 1px;
  background: var(--color-acento);
}
.prose :global(h3) {
  font-family: var(--fuente-titulo);
  font-size: 1.1rem;
  font-weight: 400;
  letter-spacing: .04em;
  color: var(--color-texto);
  margin: 1.75rem 0 .5rem;
}
.prose :global(p) { margin-bottom: 1.25rem; }
.prose :global(ul) { list-style: disc; padding-left: 1.5rem; margin-bottom: 1.25rem; }
.prose :global(li) { margin-bottom: .4rem; }
.prose :global(blockquote) {
  border-left: 3px solid var(--color-acento);
  padding: .75rem 1.5rem;
  margin: 2rem 0;
  background: var(--color-superficie);
  border-radius: 0 var(--radio-borde) var(--radio-borde) 0;
  color: var(--color-texto-sec);
  font-style: italic;
}
.prose :global(strong) { color: var(--color-texto); font-weight: 700; }
.prose :global(a) { color: var(--color-acento); }
</style>
