---
import Layout from '../layouts/Layout.astro';
import productos from '../data/tienda.json';
---

<Layout
  titulo="Tienda oficial del Torrenueva Futsal"
  descripcion="Tienda oficial del Torrenueva Futsal con equipación y camisetas del club. Consulta los productos de muestra y contacta con el equipo."
>
  <section class="seccion">
    <h1 class="titulo-seccion">Tienda oficial</h1>

    <!-- Aviso: tienda de muestra -->
    <div class="aviso aviso-amarillo">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="flex-shrink:0;margin-top:.1rem"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
      <p>
        <strong>Tienda de muestra.</strong> Los productos mostrados son ilustrativos y
        <strong>no están disponibles para la venta online.</strong>
        Para adquirir equipación contacta directamente con el club.
      </p>
    </div>

    <ul class="cuadricula-3" role="list">
      {productos.map(p => (
        <li>
          <article class="tarjeta producto-tarjeta">
            <div class="producto-foto-wrap">
              <img
                src={p.foto}
                alt={p.nombre}
                class="producto-foto"
                loading="lazy"
                width="400"
                height="500"
              />
              <div class="producto-badge-wrap" aria-hidden="true">
                <span class="producto-no-venta">No disponible online</span>
              </div>
            </div>
            <div class="tarjeta-cuerpo">
              <h2 class="producto-nombre">{p.nombre}</h2>
              <p class="producto-desc">{p.descripcion}</p>
              <p class="producto-precio">
                {p.precio.toLocaleString('es-ES', { style: 'currency', currency: 'EUR' })}
              </p>
            </div>
          </article>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
.producto-tarjeta { display: flex; flex-direction: column; }

.producto-foto-wrap {
  position: relative;
  overflow: hidden;
  aspect-ratio: 4/5;
}
.producto-foto {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform .4s ease;
  filter: grayscale(15%);
}
.tarjeta:hover .producto-foto { transform: scale(1.05); filter: grayscale(0%); }

.producto-badge-wrap {
  position: absolute;
  bottom: .75rem;
  left: .75rem;
}
.producto-no-venta {
  display: inline-block;
  background: rgba(8,8,8,.85);
  color: var(--color-texto-sec);
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
  padding: .25rem .6rem;
  border-radius: var(--radio-borde);
  border: 1px solid var(--color-borde-hover);
}

.producto-nombre {
  font-family: var(--fuente-titulo);
  font-size: 1rem;
  font-weight: 400;
  letter-spacing: .04em;
  color: var(--color-texto);
  margin-bottom: .4rem;
  line-height: 1.25;
}

.producto-desc {
  font-size: .82rem;
  color: var(--color-texto-sec);
  margin-bottom: .85rem;
  line-height: 1.5;
}

.producto-precio {
  font-family: var(--fuente-titulo);
  font-size: 1.35rem;
  letter-spacing: .03em;
  color: var(--color-acento);
}
</style>
