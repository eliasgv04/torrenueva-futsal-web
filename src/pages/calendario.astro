---
import Layout from '../layouts/Layout.astro';
import partidosSenior from '../data/calendario-senior.json';
import partidosJuvenil from '../data/calendario-juvenil.json';

interface Partido {
  fecha: string;
  rival: string;
  condicion: 'Local' | 'Visitante';
  resultado: string | null;
}

const equipos = [
  { id: 'senior',  nombre: 'Torrenueva Futsal',         partidos: partidosSenior as Partido[] },
  { id: 'juvenil', nombre: 'Torrenueva Futsal Juvenil',  partidos: partidosJuvenil as Partido[] },
];

function formatearFecha(f: string) {
  return new Date(f + 'T12:00:00').toLocaleDateString('es-ES', {
    weekday: 'short', day: 'numeric', month: 'short', year: 'numeric',
  });
}

function tipoResultado(p: Partido) {
  if (!p.resultado) return null;
  const partes = p.resultado.split(' - ').map(Number);
  const [n, r] = p.condicion === 'Local' ? [partes[0], partes[1]] : [partes[1], partes[0]];
  return n > r ? 'victoria' : n < r ? 'derrota' : 'empate';
}
---

<Layout
  titulo="Calendario y resultados del Torrenueva Futsal"
  descripcion="Consulta el calendario, los resultados y los próximos partidos del Torrenueva Futsal senior y juvenil durante la temporada 2026/27."
>
  <section class="seccion">
    <h1 class="titulo-seccion">Calendario 2026/27</h1>

    <div class="selector-equipo" role="tablist" aria-label="Selecciona equipo">
      {equipos.map((eq, i) => (
        <button
          type="button"
          class={`selector-btn${i === 0 ? ' activo' : ''}`}
          data-equipo-btn={eq.id}
          role="tab"
          aria-selected={i === 0 ? 'true' : 'false'}
        >
          {eq.nombre}
        </button>
      ))}
    </div>

    {equipos.map((eq, i) => (
      <div class="equipo-panel" data-equipo-panel={eq.id} hidden={i !== 0}>
        {eq.partidos.length === 0 ? (
          <p class="calendario-aviso">
            El calendario de {eq.nombre} todavía no se ha publicado. En cuanto la federación lo confirme, lo añadiremos aquí.
          </p>
        ) : (
          <>
            <!-- Leyenda -->
            <div class="leyenda" role="note" aria-label="Leyenda">
              <span class="leyenda-item"><span class="badge victoria">V</span> Victoria</span>
              <span class="leyenda-item"><span class="badge empate">E</span> Empate</span>
              <span class="leyenda-item"><span class="badge derrota">D</span> Derrota</span>
              <span class="leyenda-item"><span class="badge pendiente">—</span> Pendiente</span>
            </div>

            <div class="tabla-wrap">
              <table class="tabla" aria-label={`Partidos de ${eq.nombre}`}>
                <thead>
                  <tr>
                    <th scope="col">Fecha</th>
                    <th scope="col">Rival</th>
                    <th scope="col">Condición</th>
                    <th scope="col" class="col-resultado">Resultado</th>
                  </tr>
                </thead>
                <tbody>
                  {eq.partidos.map(p => {
                    const tipo = tipoResultado(p);
                    return (
                      <tr class={`fila fila-${tipo ?? 'pendiente'}`}>
                        <td class="celda-fecha">
                          <time datetime={p.fecha}>{formatearFecha(p.fecha)}</time>
                        </td>
                        <td class="celda-rival">{p.rival}</td>
                        <td>
                          <span class={`condicion condicion-${p.condicion.toLowerCase()}`}>
                            {p.condicion}
                          </span>
                        </td>
                        <td class="celda-resultado">
                          {p.resultado
                            ? <span class={`badge ${tipo}`}>{p.resultado}</span>
                            : <span class="badge pendiente">Pendiente</span>
                          }
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </>
        )}
      </div>
    ))}
  </section>
</Layout>

<script>
  const botones = document.querySelectorAll<HTMLButtonElement>('[data-equipo-btn]');
  const paneles = document.querySelectorAll<HTMLElement>('[data-equipo-panel]');

  botones.forEach(boton => {
    boton.addEventListener('click', () => {
      const id = boton.dataset.equipoBtn;

      botones.forEach(b => {
        const activo = b === boton;
        b.classList.toggle('activo', activo);
        b.setAttribute('aria-selected', String(activo));
      });

      paneles.forEach(panel => {
        panel.hidden = panel.dataset.equipoPanel !== id;
      });
    });
  });
</script>

<style>
.selector-equipo {
  display: flex;
  gap: .6rem;
  flex-wrap: wrap;
  margin-bottom: 2.5rem;
}
.selector-btn {
  font-family: inherit;
  font-size: .8rem;
  font-weight: 700;
  letter-spacing: .04em;
  color: var(--color-texto-sec);
  background: transparent;
  border: 1px solid var(--color-borde);
  border-radius: var(--radio-borde);
  padding: .6rem 1.2rem;
  cursor: pointer;
  transition: color .15s, border-color .15s, background .15s;
}
.selector-btn:hover { color: var(--color-texto); border-color: var(--color-borde-hover); }
.selector-btn.activo {
  color: #000;
  background: var(--color-acento);
  border-color: var(--color-acento);
}

.calendario-aviso {
  color: var(--color-texto-sec);
  font-size: .95rem;
  border: 1px solid var(--color-borde);
  border-radius: var(--radio-lg);
  padding: 2.5rem 1.5rem;
  text-align: center;
}

.leyenda {
  display: flex;
  gap: 1.5rem;
  flex-wrap: wrap;
  margin-bottom: 2rem;
  font-size: .8rem;
  color: var(--color-texto-sec);
}
.leyenda-item { display: flex; align-items: center; gap: .45rem; }

/* Tabla */
.tabla-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  border: 1px solid var(--color-borde);
  border-radius: var(--radio-lg);
}

.tabla {
  width: 100%;
  border-collapse: collapse;
  font-size: .9rem;
  min-width: 520px;
}

.tabla thead th {
  background: var(--color-superficie-2);
  color: var(--color-texto-sec);
  padding: .85rem 1.25rem;
  text-align: left;
  font-size: .7rem;
  font-weight: 700;
  letter-spacing: .12em;
  text-transform: uppercase;
  border-bottom: 1px solid var(--color-borde);
}
.col-resultado { text-align: center; }

.tabla tbody .fila {
  border-bottom: 1px solid var(--color-borde);
  transition: background .15s;
}
.tabla tbody .fila:last-child { border-bottom: none; }
.tabla tbody .fila:hover { background: var(--color-superficie-2); }

.tabla td { padding: 1rem 1.25rem; vertical-align: middle; }

/* Indicador lateral por resultado */
.fila-victoria { border-left: 3px solid #4caf50; }
.fila-derrota  { border-left: 3px solid #ef5350; }
.fila-empate   { border-left: 3px solid var(--color-acento); }
.fila-pendiente { border-left: 3px solid var(--color-borde); }

.celda-fecha {
  font-size: .8rem;
  color: var(--color-texto-sec);
  white-space: nowrap;
}

.celda-rival {
  font-weight: 600;
  color: var(--color-texto);
}

.celda-resultado { text-align: center; }

/* Condición */
.condicion {
  display: inline-block;
  padding: .2rem .65rem;
  border-radius: var(--radio-borde);
  font-size: .72rem;
  font-weight: 700;
  letter-spacing: .08em;
  text-transform: uppercase;
}
.condicion-local     { background: rgba(26,92,46,.2); color: #4caf50; border: 1px solid rgba(26,92,46,.4); }
.condicion-visitante { background: rgba(245,197,24,.1); color: var(--color-acento); border: 1px solid rgba(245,197,24,.3); }
</style>
